# Application
NODE_ENV=development
PORT=3000
# Public trace + QR codes use this origin (must be reachable from the phone when testing scans).
FRONTEND_URL=http://localhost:4200

# Packaging PDF labels + public branding (GET .../public/branding, PDF labels).
# LABEL_BRAND_NAME drives: landing toolbar = brand only; platform UI = "${BRAND} Supply Tracking".
# LABEL_LOGO_URL=
# LABEL_BRAND_NAME=MAREA ALTA

# Optional: override landing toolbar text only (e.g. MAREA ALTA). When unset, uses LABEL_BRAND_NAME uppercased.
# PUBLIC_LANDING_TITLE=

# Legacy: override landing toolbar if PUBLIC_LANDING_TITLE is unset. Prefer PUBLIC_LANDING_TITLE.
# PUBLIC_HEADER_TITLE=

# CORS: comma-separated allowed origins. If unset in development, all origins are reflected (origin: true).
# In production, either set CORS_ORIGIN or rely on FRONTEND_URL as the single allowed origin.
# CORS_ORIGIN=https://app.example.com,https://staging.example.com

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/supply_tracking?schema=public"

# JWT (required in production; must not be the dev placeholder)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
